# Application
NEXT_PUBLIC_APP_URL=
ADMIN_EMAILS=

# Supabase
# NEXT_PUBLIC_* values are browser-visible and must only contain public Supabase project values.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Never expose this as NEXT_PUBLIC_* and never import server clients into client components.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# AI runtime
AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEXT_MODEL=deepseek-chat
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Future billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
