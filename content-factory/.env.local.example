# AI provider: use "openai" for real generation; use "local" only for demo mode.
# openai | gemini | deepseek | alternative | local
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=low
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_REQUEST_TIMEOUT_MS=45000

# Optional proxy support. Leave both empty unless your network requires a proxy.
HTTP_PROXY=
HTTPS_PROXY=
ALTERNATIVE_API_BASE_URL=
ALTERNATIVE_API_KEY=
ALTERNATIVE_TEXT_MODEL=
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
# Optional: set only after enabling a Gemini model that supports IMAGE output.
GEMINI_IMAGE_MODEL=
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEXT_MODEL=deepseek-chat

# Supabase: required for persistent tasks, content, assets, and generation records.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=
