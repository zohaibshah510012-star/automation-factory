# Automation Factory production site template.
# Replace example.com with your domain and configure certificates through Baota,
# certbot, or your preferred certificate manager before enabling HTTPS traffic.

upstream automation_factory_web {
  server 127.0.0.1:3000;
  keepalive 32;
}

server {
  listen 80;
  server_name example.com www.example.com;

  # If HTTPS is enabled, redirect all HTTP traffic.
  # return 301 https://$host$request_uri;

  location / {
    proxy_pass http://automation_factory_web;
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection "upgrade";
    proxy_read_timeout 120s;
    proxy_send_timeout 120s;
  }
}

