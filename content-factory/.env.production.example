NODE_ENV=production
NEXT_PUBLIC_APP_URL=https://your-domain.com
ADMIN_EMAILS=founder@your-domain.com
BETA_INVITE_ONLY=true

# Supabase
# NEXT_PUBLIC_* values are browser-visible. Never put private keys here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Core AI provider selection
AI_PROVIDER=deepseek
# openai | gemini | flux | local. Use local only as a Beta fallback; use an external provider for production AI image generation.
AI_IMAGE_PROVIDER=openai
AI_VIDEO_PROVIDER=local

# DeepSeek text provider
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_TEXT_MODEL=deepseek-chat
DEEPSEEK_REQUEST_TIMEOUT_MS=45000

# OpenAI text/image/audio provider
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_QUALITY=low
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=coral
OPENAI_REQUEST_TIMEOUT_MS=180000

# Optional providers
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=
ANTHROPIC_API_KEY=
FLUX_API_KEY=
FLUX_API_BASE_URL=
FLUX_IMAGE_MODEL=flux-1.1-pro
RUNWAY_API_KEY=
RUNWAY_API_BASE_URL=
RUNWAY_VIDEO_MODEL=gen4_turbo
KLING_API_KEY=
KLING_API_BASE_URL=
KLING_VIDEO_MODEL=kling-v1

# Billing and payment
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
CREDIT_PRICE_USD=0.05
PROVIDER_COST_PER_CREDIT_USD=0.01
AI_COST_TRACKING_ENABLED=true
DAILY_GENERATION_LIMIT_FREE=
DAILY_GENERATION_LIMIT_PRO=

# Email, storage, webhooks, and scheduled jobs
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
STORAGE_BUCKET=
WEBHOOK_SIGNING_SECRET=
CRON_SECRET=
WORKER_MODE=false

# Optional outbound proxy for provider access from restricted VPS networks
HTTP_PROXY=
HTTPS_PROXY=
